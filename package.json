{
  "name": "mission-spec",
  "version": "1.5.0",
  "description": "Mission Spec — AI 에이전트 워크플로를 위한 task contract layer",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./commands/init": {
      "types": "./dist/commands/init.d.ts",
      "import": "./dist/commands/init.js"
    },
    "./commands/eval": {
      "types": "./dist/commands/eval.d.ts",
      "import": "./dist/commands/eval.js"
    },
    "./commands/status": {
      "types": "./dist/commands/status.d.ts",
      "import": "./dist/commands/status.js"
    },
    "./commands/report": {
      "types": "./dist/commands/report.d.ts",
      "import": "./dist/commands/report.js"
    }
  },
  "scripts": {
    "snapshot": "node scripts/snapshot-mission.js",
    "build": "tsc && cp src/schema/*.schema.json dist/schema/",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "mission-spec",
    "ai-agent",
    "task-contract",
    "claude-code-plugin"
  ],
  "author": "Dr. QUAN",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "@types/node": "^20.0.0"
  },
  "dependencies": {
    "ajv": "^8.13.0",
    "yaml": "^2.4.0"
  }
}
