{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://mission-spec.dev/schema/v1/mission.schema.json",
  "title": "Mission Spec",
  "description": "Task contract for AI agent workflows",
  "type": "object",
  "required": ["mission"],
  "additionalProperties": false,
  "properties": {
    "mission": {
      "type": "object",
      "required": ["title", "goal", "done_when"],
      "additionalProperties": false,
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1,
          "description": "Mission title"
        },
        "goal": {
          "type": "string",
          "minLength": 1,
          "description": "Mission goal (natural language)"
        },
        "done_when": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1,
          "description": "Completion criteria list"
        },
        "constraints": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "description": "Constraint list"
        },
        "approvals": {
          "type": "array",
          "items": { "$ref": "#/definitions/Approval" },
          "description": "Approval gate list"
        },
        "evals": {
          "type": "array",
          "items": { "$ref": "#/definitions/Eval" },
          "description": "Evaluation item list"
        },
        "budget_hint": {
          "$ref": "#/definitions/BudgetHint",
          "description": "Resource budget hint (advisory)"
        },
        "execution_hints": {
          "$ref": "#/definitions/ExecutionHints",
          "description": "Execution hints (advisory only — runtime may ignore)"
        },
        "skills_needed": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "description": "Required skills list"
        },
        "artifacts": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "description": "Artifact pattern list"
        },
        "version": {
          "type": "string",
          "description": "Mission spec version"
        },
        "author": {
          "type": "string",
          "description": "Author"
        },
        "created": {
          "type": "string",
          "description": "Creation date"
        },
        "lineage": {
          "$ref": "#/definitions/Lineage",
          "description": "Change history reference (optional)"
        },
        "design_refs": {
          "$ref": "#/definitions/DesignRefs",
          "description": "Design document location pointers (optional) — architecture, API, type definitions, etc."
        }
      }
    }
  },
  "definitions": {
    "Approval": {
      "type": "object",
      "required": ["gate", "approver"],
      "additionalProperties": false,
      "properties": {
        "gate": {
          "type": "string",
          "minLength": 1,
          "description": "Approval gate name"
        },
        "approver": {
          "type": "string",
          "enum": ["human", "ai", "codex", "ci"],
          "description": "Approver type"
        },
        "description": {
          "type": "string",
          "description": "Approval condition description"
        }
      }
    },
    "Eval": {
      "type": "object",
      "required": ["name", "type"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Evaluation name"
        },
        "type": {
          "type": "string",
          "enum": ["automated", "manual", "llm-judge", "llm-eval"],
          "description": "Evaluation type"
        },
        "command": {
          "type": "string",
          "description": "Automated evaluation command"
        },
        "pass_criteria": {
          "type": "string",
          "description": "Pass criteria"
        },
        "description": {
          "type": "string",
          "description": "Manual evaluation description"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "type": { "const": "automated" } },
            "required": ["type"]
          },
          "then": {
            "required": ["name", "type", "command", "pass_criteria"]
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "manual" } },
            "required": ["type"]
          },
          "then": {
            "required": ["name", "type", "description"]
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "llm-eval" } },
            "required": ["type"]
          },
          "then": {
            "required": ["name", "type", "pass_criteria"]
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "llm-judge" } },
            "required": ["type"]
          },
          "then": {
            "required": ["name", "type", "pass_criteria"]
          }
        }
      ]
    },
    "BudgetHint": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "max_tokens_per_session": {
          "type": "integer",
          "minimum": 1
        },
        "max_parallel_agents": {
          "type": "integer",
          "minimum": 1
        },
        "estimated_sessions": {
          "type": "integer",
          "minimum": 1
        },
        "priority": {
          "type": "string"
        }
      }
    },
    "ExecutionHints": {
      "type": "object",
      "additionalProperties": true,
      "description": "Advisory only — runtime may ignore",
      "properties": {
        "topology": {
          "type": "string",
          "description": "Suggested execution topology"
        },
        "suggested_approach": {
          "type": "string",
          "description": "Suggested approach"
        },
        "note": {
          "type": "string",
          "description": "Additional notes"
        }
      }
    },
    "DesignRefs": {
      "type": "object",
      "additionalProperties": false,
      "description": "Project design document location pointers. Declares paths only, not actual design content.",
      "properties": {
        "architecture": {
          "type": "string",
          "description": "Architecture document path (e.g., docs/internal/ARCHITECTURE.md)"
        },
        "api_surface": {
          "type": "string",
          "description": "Public API definition file path (e.g., src/index.ts)"
        },
        "type_definitions": {
          "type": "string",
          "description": "Core type definition file path (e.g., src/core/parser.ts)"
        },
        "component_protocol": {
          "type": "string",
          "description": "Inter-component data flow document path"
        }
      }
    },
    "Lineage": {
      "type": "object",
      "required": ["initial_version", "history"],
      "additionalProperties": false,
      "description": "Metadata for change history tracking",
      "properties": {
        "initial_version": {
          "type": "string",
          "description": "Initial version"
        },
        "initial_date": {
          "type": "string",
          "description": "Initial creation date"
        },
        "total_revisions": {
          "type": "integer",
          "minimum": 0,
          "description": "Total revision count"
        },
        "history": {
          "type": "string",
          "description": "Change history file path"
        }
      }
    }
  }
}
